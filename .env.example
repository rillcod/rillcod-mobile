# Supabase Configuration
# Copy to `.env` and fill with values from Supabase Dashboard → Project Settings → API.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_PROJECT_ID=your_project_ref

# Personal Access Token for CLI (supabase link, functions deploy, secrets)
# Dashboard → Account → Access Tokens — never commit the real value.
SUPABASE_ACCESS_TOKEN=your_supabase_personal_access_token

# Service Role Key (Admin Access) — DO NOT EXPOSE TO FRONTEND; server / Edge Functions only
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paystack
# ── Webhook URL: use ONLY ONE in Paystack Dashboard → Settings → Webhooks (charge.success).
#     A) Supabase Edge (recommended): https://YOUR_PROJECT_REF.supabase.co/functions/v1/paystack-webhook
#     B) If you use another backend (e.g. Next.js), avoid duplicating fulfillment logic.
#
# ── Supabase secrets (not Expo): npx supabase secrets set PAYSTACK_SECRET_KEY=sk_...
#     Optional: npx supabase secrets set PAYSTACK_CALLBACK_URL=https://your-site.com/payment/return
#
# Mobile default: paystack-initialize can use Supabase return page:
#   https://YOUR_PROJECT_REF.supabase.co/functions/v1/paystack-callback
PAYSTACK_SECRET_KEY=sk_live_or_test_secret
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_or_test_public

# OpenRouter API Key (Alternative to DB storage)
EXPO_PUBLIC_OPENROUTER_API_KEY=

# AI Generation (OpenRouter) — server-side if used by Edge Functions / backend
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# Hugging Face
HUGGINGFACE_API_KEY=hf_your_huggingface_token

# Cloudflare R2 Storage (server-side only — never use EXPO_PUBLIC_ prefix)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=your_bucket_name
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# Custom domain or public bucket URL for client-readable assets
R2_PUBLIC_URL=https://your-cdn-or-public-base-url
